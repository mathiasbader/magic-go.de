{
    "name": "mathiasbader/magic-go",
    "description": "Magic: The Gathering collection manager",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.2",
        "twig/twig": "^3.24"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1"
    },
    "scripts": {
        "stan": "phpstan analyse"
    },
    "autoload": {
        "psr-4": {
            "Magic\\": "src/Magic/"
        },
        "classmap": [
            "src/Service/"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
